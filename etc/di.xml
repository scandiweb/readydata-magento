<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Service contracts -->
    <preference for="ReadyData\Import\Api\ProductImportInterface"
                type="ReadyData\Import\Model\ProductImport"/>
    <preference for="ReadyData\Import\Api\Data\ProductInterface"
                type="ReadyData\Import\Model\Data\Product"/>
    <preference for="ReadyData\Import\Api\Data\CustomAttributeInterface"
                type="ReadyData\Import\Model\Data\CustomAttribute"/>
    <preference for="ReadyData\Import\Api\Data\StockDataInterface"
                type="ReadyData\Import\Model\Data\StockData"/>
    <preference for="ReadyData\Import\Api\Data\ConfigurableDataInterface"
                type="ReadyData\Import\Model\Data\ConfigurableData"/>
    <preference for="ReadyData\Import\Api\Data\ImportSettingsInterface"
                type="ReadyData\Import\Model\Data\ImportSettings"/>
    <preference for="ReadyData\Import\Api\Data\ImportResultInterface"
                type="ReadyData\Import\Model\Data\ImportResult"/>
    <preference for="ReadyData\Import\Api\Data\ImportResponseInterface"
                type="ReadyData\Import\Model\Data\ImportResponse"/>

    <!-- Dedicated log file: var/log/readydata_import.log -->
    <type name="ReadyData\Import\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">readydata_import</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ReadyData\Import\Logger\Handler</item>
            </argument>
        </arguments>
    </type>

    <!--
        The import pipeline. Order is controlled by each processor's
        getSortOrder(); add third-party steps by appending items here.
        Placeholder processors report isEnabled() = false until implemented.
    -->
    <type name="ReadyData\Import\Model\ImportService">
        <arguments>
            <argument name="processors" xsi:type="array">
                <item name="attributes" xsi:type="object">ReadyData\Import\Model\Processor\AttributeProcessor</item>
                <item name="entity" xsi:type="object">ReadyData\Import\Model\Processor\EntityProcessor</item>
                <item name="eav_values" xsi:type="object">ReadyData\Import\Model\Processor\EavValueProcessor</item>
                <item name="websites" xsi:type="object">ReadyData\Import\Model\Processor\WebsiteProcessor</item>
                <item name="stock" xsi:type="object">ReadyData\Import\Model\Processor\StockProcessor</item>
                <item name="url_rewrites" xsi:type="object">ReadyData\Import\Model\Processor\UrlRewriteProcessor</item>
                <item name="category_links" xsi:type="object">ReadyData\Import\Model\Processor\CategoryLinkProcessor</item>
                <!-- Placeholders for further expansion -->
                <item name="media" xsi:type="object">ReadyData\Import\Model\Processor\MediaProcessor</item>
                <item name="links" xsi:type="object">ReadyData\Import\Model\Processor\LinkProcessor</item>
                <item name="configurables" xsi:type="object">ReadyData\Import\Model\Processor\ConfigurableProcessor</item>
                <item name="tier_prices" xsi:type="object">ReadyData\Import\Model\Processor\TierPriceProcessor</item>
            </argument>
        </arguments>
    </type>

    <!--
        Event dispatch is configured under Stores > Configuration > ReadyData >
        Product Import > Events. When the "Also Dispatch catalog_product_save_after"
        setting is on, the native URL-rewrite/inventory observers are suppressed
        for the duration of the import (see the plugins below) so they never
        double-write.
    -->

    <!-- Import-active flag consulted by the observer-suppression plugins; must be shared -->
    <type name="ReadyData\Import\Model\ImportState" shared="true"/>

    <type name="Magento\CatalogUrlRewrite\Observer\ProductProcessUrlRewriteSavingObserver">
        <plugin name="readydata_suppress_url_rewrite_during_import"
                type="ReadyData\Import\Plugin\CatalogUrlRewrite\SuppressUrlRewriteDuringImport"/>
    </type>
    <type name="Magento\CatalogInventory\Observer\SaveInventoryDataObserver">
        <plugin name="readydata_suppress_inventory_save_during_import"
                type="ReadyData\Import\Plugin\CatalogInventory\SuppressInventorySaveDuringImport"/>
    </type>

    <!-- Request-scoped caches must be shared instances (default), listed here for clarity -->
    <type name="ReadyData\Import\Model\Cache\AttributeMetadataCache" shared="true"/>
    <type name="ReadyData\Import\Model\Cache\StoreWebsiteMap" shared="true"/>
    <type name="ReadyData\Import\Model\Cache\CategoryPathResolver" shared="true"/>
    <type name="ReadyData\Import\Model\ResourceModel\AttributeOption" shared="true"/>
    <type name="ReadyData\Import\Model\ResourceModel\Category" shared="true"/>
</config>
