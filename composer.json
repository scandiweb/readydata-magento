{
    "name": "readydata/module-import",
    "description": "ReadyData bulk product import for Magento 2 via direct database writes",
    "type": "magento2-module",
    "license": "proprietary",
    "version": "0.1.0",
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": ">=103.0.0",
        "magento/module-catalog": ">=104.0.0",
        "magento/module-configurable-product": ">=100.4.0",
        "magento/module-eav": ">=102.0.0",
        "magento/module-store": ">=101.0.0"
    },
    "suggest": {
        "magento/module-inventory-api": "Multi Source Inventory (MSI) stock updates"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "ReadyData\\Import\\": ""
        }
    }
}
